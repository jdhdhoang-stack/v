rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) 
        && data.uid == request.auth.uid 
        && data.email is string && data.email.size() <= 128
        && data.createdAt == request.time
        && (data.photoURL == null || data.photoURL is string)
        && (data.displayName == null || data.displayName is string);
    }

    function isValidScript(data) {
      return data.keys().hasAll(['userId', 'content', 'createdAt'])
        && data.userId == request.auth.uid
        && data.content is string && data.content.size() <= 50000
        && data.createdAt == request.time;
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        // Validation check for updates (ensure immutable fields like uid/email stay same)
        incoming().uid == existing().uid &&
        incoming().email == existing().email &&
        incoming().updatedAt == request.time &&
        incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'blurConfig', 'subtitleConfig', 'updatedAt'])
      );
    }

    match /users/{userId}/scripts/{scriptId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(scriptId) && isValidScript(incoming());
      allow update, delete: if isOwner(userId);
    }
  }
}
