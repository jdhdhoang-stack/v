{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stored user preferences and metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "blurConfig": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number" },
            "height": { "type": "number" },
            "amount": { "type": "number" }
          }
        },
        "subtitleConfig": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number" },
            "bottomMargin": { "type": "number" },
            "color": { "type": "string" },
            "shadow": { "type": "boolean" },
            "enabled": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Script": {
      "title": "AI Script",
      "description": "Scripts generated by AI or entered by user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "content": { "type": "string" },
        "length": { "type": "string", "enum": ["short", "medium", "long"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and settings"
    },
    "/users/{userId}/scripts/{scriptId}": {
      "schema": "Script",
      "description": "User saved scripts"
    }
  }
}
